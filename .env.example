# PostgreSQL ulanish manzili
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/habit_tracker?schema=public"

# Server porti
PORT=5000

# JWT sirli kaliti (production uchun murakkab qiymat qo'ying!)
JWT_SECRET="super_secret_key_change_this"

# JWT token amal qilish muddati
JWT_EXPIRES_IN="7d"

# --- PRO (Dark Elite) tarif sozlamalari ---
PRO_PLAN_PRICE=49000
PRO_PLAN_DURATION_DAYS=30

# --- Payme ---
PAYME_MERCHANT_ID="your_payme_merchant_id"
PAYME_KEY="your_payme_secret_key"

# --- Click ---
CLICK_SERVICE_ID="your_click_service_id"
CLICK_MERCHANT_ID="your_click_merchant_id"
CLICK_SECRET_KEY="your_click_secret_key"

# --- Stripe ---
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
